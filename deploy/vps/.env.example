# Quick — environment for the compose stack (installed to /opt/quick/.env).
# Secrets live ONLY here; never commit a filled-in copy. The proxy/domain wiring is
# in quick.conf; the app derives its own domain from BETTER_AUTH_URL.
#
# The app container gets ONLY the app config below (see compose's `environment:`).
# The STORAGE_BOX_*/RESTIC_* backup creds are read solely by the litestream/restic
# services via ${...} substitution and are never injected into the app. NODE_ENV,
# DATABASE_PATH and PORT are baked into the image.

# Activates the prod compose profile for every `docker compose` run in /opt/quick
# (so `docker compose up -d` / `ps` need no --profile flag).
COMPOSE_PROFILES=prod

# Loopback port the app binds on the host. Keep in sync with APP_PORT in quick.conf.
APP_PORT=8003

# Public origin the browser loads. The server derives the app root domain from this,
# and Better Auth uses it as the OAuth callback origin. MUST be https://<QUICK_DOMAIN>.
BETTER_AUTH_URL=https://quick.example.com

# 32+ char random secret. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Google OAuth client (type "Web application"). One authorized redirect URI:
#   https://quick.example.com/api/auth/callback/google
GOOGLE_ID=
GOOGLE_SECRET=

# Comma-separated OWNER emails (dashboard + deploy API + MCP). Any other Google
# account can still VIEW a google-mode app but has no owner powers.
QUICK_ALLOWED_EMAILS=

# Public host the MCP endpoint (/mcp) is reached at (DNS-rebinding allowlist).
MCP_HOST=quick.example.com

# --- Backups: read by the litestream/restic services, NOT the app ----------
# S3-compatible object storage credentials (e.g. Hetzner Storage Box).
STORAGE_BOX_KEY=
STORAGE_BOX_SECRET=
# STORAGE_BOX_ENDPOINT=fsn1.your-objectstorage.com
# STORAGE_BOX_BUCKET=quick-backup

# restic repository + password for /data/apps backups (uses STORAGE_BOX_* creds).
# e.g. s3:https://fsn1.your-objectstorage.com/quick-backup/apps
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
