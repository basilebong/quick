# Template — setup.sh renders the @@PLACEHOLDERS@@ from quick.conf and appends the
# result (between the markers) to /etc/caddy/Caddyfile. Do not append by hand.
#
# >>> quick BEGIN (managed by deploy/vps/setup.sh — do not edit between markers) >>>
# Companion edit by setup.sh (Caddy allows only ONE global options block, so it is
# merged into the existing one rather than added here):
#     on_demand_tls { ask @@ASK_URL@@ }
# Caddy calls GET <ask>?domain=<sni-host> before issuing an on-demand cert; the app
# answers 2xx only for the apex + real deployed slugs (tls-check.ts), so certs are
# never minted for arbitrary hostnames aimed at the IP.

# Apex: dashboard + owner API + MCP. Cert via the normal HTTP-01 managed flow.
@@QUICK_DOMAIN@@ {
	encode zstd gzip
	header {
		-Server
		-X-Powered-By
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}
	# The on-demand `ask` endpoint is for Caddy's own loopback call only; never
	# expose it through the public vhost (it would be a deployed-slug oracle).
	handle /_internal/* {
		respond 404
	}
	handle {
		reverse_proxy @@APP_ADDR@@
	}
}

# Deployed apps on wildcard subdomains. `on_demand` issues a per-subdomain cert via
# HTTP-01 on first request, gated by the global on_demand_tls `ask` above.
# `header_up Host {host}` preserves the subdomain so the Bun app resolves the tenant.
*.@@QUICK_DOMAIN@@ {
	encode zstd gzip
	tls {
		on_demand
	}
	header {
		-Server
		-X-Powered-By
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}
	handle /_internal/* {
		respond 404
	}
	handle {
		reverse_proxy @@APP_ADDR@@ {
			header_up Host {host}
		}
	}
}
