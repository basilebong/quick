# ---------------------------------------------------------------------------
# Quick configuration. Copy to .env and fill in. NEVER commit .env.
# ---------------------------------------------------------------------------

# The root domain Quick is served at. The dashboard lives at this host; apps live
# at <slug>.${QUICK_DOMAIN}. Point DNS A/AAAA records for both `quick` (apex) and
# `*.quick` (wildcard) at the VPS. Used by Caddy.
QUICK_DOMAIN=quick.example.com

# Email for the ACME account (Let's Encrypt) Caddy uses to issue certs.
ACME_EMAIL=you@example.com

# Hetzner DNS API token, scoped to the zone above. Powers the DNS-01 challenge
# for the *.${QUICK_DOMAIN} wildcard certificate. Lives only here, never in CI.
HETZNER_DNS_API_TOKEN=

# Public origin the browser loads. The server derives the app root domain from
# this, and Better Auth uses it as the OAuth callback origin + apex cookie scope.
# Local dev (Vite): http://localhost:5173
# Production: https://${QUICK_DOMAIN}
BETTER_AUTH_URL=http://localhost:5173

# 32+ char random secret. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32

# Google OAuth Client (https://console.cloud.google.com/apis/credentials),
# type "Web application". ONE authorized redirect URI (the apex):
#   http://localhost:5173/api/auth/callback/google     (local dev)
#   https://${QUICK_DOMAIN}/api/auth/callback/google    (production)
GOOGLE_ID=
GOOGLE_SECRET=

# Comma-separated OWNER emails. These accounts may use the dashboard, the deploy
# API, and the MCP tools. Any OTHER Google account can still VIEW a google-mode
# app (that is the "anyone with the link" share mode) but has no owner powers.
QUICK_ALLOWED_EMAILS=

# Public Host the MCP endpoint (/mcp) is reached at (DNS-rebinding allowlist).
# Production: ${QUICK_DOMAIN}. Local dev can leave this as-is.
MCP_HOST=localhost

# SQLite path and the on-disk root for deployed app bundles + uploaded files.
# APPS_DIR defaults to <dir of DATABASE_PATH>/apps if unset.
DATABASE_PATH=./data/app.db
# APPS_DIR=/data/apps

# How long (days) to retain per-app access-log entries (who viewed a shared app,
# when, via which link). Older entries are purged automatically. Defaults to 30.
# QUICK_ACCESS_LOG_RETENTION_DAYS=30

NODE_ENV=development
PORT=3000

# Object storage (S3-compatible, e.g. Hetzner) for backups.
# Litestream (db) credentials:
STORAGE_BOX_KEY=
STORAGE_BOX_SECRET=
# STORAGE_BOX_ENDPOINT=fsn1.your-objectstorage.com
# STORAGE_BOX_BUCKET=quick-backup

# restic repository + password for /data/apps backups (uses STORAGE_BOX_* creds).
# e.g. s3:https://fsn1.your-objectstorage.com/quick-backup/apps
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
