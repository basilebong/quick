{
	email {$ACME_EMAIL}
}

# Apex: dashboard + owner API + MCP. HTTP-01 challenge (independent of DNS-01, so
# a DNS-token misconfig can't take the apex TLS down with it).
{$QUICK_DOMAIN} {
	encode zstd gzip
	# /_internal/* is the loopback on-demand-TLS `ask` surface; never serve it
	# publicly (it would be a deployed-slug oracle via tls-check.ts). This wildcard
	# setup uses DNS-01, so nothing legitimate reaches it through the public vhost.
	handle /_internal/* {
		respond 404
	}
	handle {
		reverse_proxy app:3000
	}
}

# Deployed apps live on wildcard subdomains. The wildcard cert needs the DNS-01
# challenge via the Hetzner DNS plugin (see Dockerfile.caddy). `header_up Host`
# preserves the subdomain so the Bun app can resolve the tenant.
*.{$QUICK_DOMAIN} {
	encode zstd gzip
	tls {
		dns hetzner {env.HETZNER_DNS_API_TOKEN}
	}
	handle /_internal/* {
		respond 404
	}
	handle {
		reverse_proxy app:3000 {
			header_up Host {host}
		}
	}
}
