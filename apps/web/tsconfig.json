{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "e2e/**/*"],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "../../packages/core" },
    { "path": "../../packages/app-hosting" },
    { "path": "../../packages/app-store" },
    { "path": "../../packages/app-files" }
  ]
}
